@PACKAGE_INIT@

# Whether the SDK was built with remote access gateway support.
set(FOXGLOVE_SDK_REMOTE_ACCESS @FOXGLOVE_REMOTE_ACCESS@)

set(_foxglove_lib_dir "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@")
set(_foxglove_bin_dir "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_BINDIR@")

# Import the Rust/C library targets. On Windows the shared .dll lives in BINDIR
# (per GNUInstallDirs) and is paired with a .dll.lib import library in LIBDIR;
# on POSIX the .so/.dylib is both runtime and link artifact and lives in LIBDIR.
# RA installs don't ship the static C lib, but the helper handles that via an
# EXISTS check internally — no caller-side gating needed.
include("${CMAKE_CURRENT_LIST_DIR}/foxglove-c-imports.cmake")
if(WIN32)
  foxglove_sdk_import_c_libs(
    STATIC_LIB "${_foxglove_lib_dir}/${CMAKE_STATIC_LIBRARY_PREFIX}foxglove${CMAKE_STATIC_LIBRARY_SUFFIX}"
    SHARED_LIB "${_foxglove_bin_dir}/${CMAKE_SHARED_LIBRARY_PREFIX}foxglove${CMAKE_SHARED_LIBRARY_SUFFIX}"
    SHARED_IMPLIB "${_foxglove_lib_dir}/foxglove.dll.lib"
  )
else()
  foxglove_sdk_import_c_libs(
    STATIC_LIB "${_foxglove_lib_dir}/${CMAKE_STATIC_LIBRARY_PREFIX}foxglove${CMAKE_STATIC_LIBRARY_SUFFIX}"
    SHARED_LIB "${_foxglove_lib_dir}/${CMAKE_SHARED_LIBRARY_PREFIX}foxglove${CMAKE_SHARED_LIBRARY_SUFFIX}"
  )
endif()

unset(_foxglove_lib_dir)
unset(_foxglove_bin_dir)

include("${CMAKE_CURRENT_LIST_DIR}/foxglove-sdkTargets.cmake")

check_required_components(foxglove-sdk)
